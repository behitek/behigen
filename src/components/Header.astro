---
import ThemeToggle from '@components/ThemeToggle.astro';

const baseUrl = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const links = [
  { href: `${baseUrl}store`, label: 'Cửa hàng' },
  { href: `${baseUrl}blog`, label: 'Blog' },
  { href: `${baseUrl}tools`, label: 'Công cụ' },
  { href: `${baseUrl}faq`, label: 'FAQ' },
  { href: `${baseUrl}contact`, label: 'Liên hệ' }
];
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <nav class="container flex items-center justify-between py-4">
    <a href={baseUrl} class="text-xl font-black tracking-tight text-slate-950">Behigen</a>
    <div class="hidden items-center gap-5 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-semibold transition hover:text-cyan-700',
            currentPath.startsWith(link.href.replace(baseUrl, '/')) ? 'text-cyan-700' : 'text-slate-700'
          ]}
        >
          {link.label}
        </a>
      ))}
      <ThemeToggle />
    </div>
    <details class="md:hidden">
      <summary class="cursor-pointer list-none rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">
        Menu
      </summary>
      <div class="absolute right-4 top-16 w-56 rounded-3xl border border-slate-200 bg-white p-4 shadow-xl">
        <div class="flex flex-col gap-3">
          {links.map((link) => (
            <a href={link.href} class="text-sm font-semibold text-slate-700">
              {link.label}
            </a>
          ))}
          <ThemeToggle />
        </div>
      </div>
    </details>
  </nav>
</header>
