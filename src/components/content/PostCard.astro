---
import { normalizePathWithBase } from '@utils/seo';

const { post } = Astro.props;
const thumbnailSrc = post.data.thumbnail
  ? normalizePathWithBase({
      path: post.data.thumbnail,
      basePath: import.meta.env.BASE_URL,
    })
  : undefined;
---

<article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
  {thumbnailSrc && (
    <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="block aspect-[16/10] overflow-hidden bg-slate-100">
      <img
        src={thumbnailSrc}
        alt={post.data.title}
        class="h-full w-full object-cover"
        loading="lazy"
        referrerpolicy="no-referrer"
      />
    </a>
  )}
  <div class="p-6">
    <div class="flex flex-wrap items-center gap-3">
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-cyan-700">{post.data.category}</p>
      {post.data.sourceLabel && (
        <p class="rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600">
          {post.data.sourceLabel}
        </p>
      )}
    </div>
    <h3 class="mt-4 text-xl font-black text-slate-950">
      <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`}>{post.data.title}</a>
    </h3>
    <p class="mt-3 text-sm leading-6 text-slate-600">{post.data.description}</p>
    <div class="mt-5 flex items-center justify-between gap-4">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">
        {post.data.pubDate.toLocaleDateString('vi-VN')}
      </p>
      <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="text-sm font-semibold text-cyan-700">
        Đọc bài
      </a>
    </div>
  </div>
</article>
