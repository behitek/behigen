---
const { items, title = 'Điểm nổi bật' } = Astro.props;
---

<section class="rounded-[2rem] border border-slate-200 bg-white p-6">
  <h2 class="text-2xl font-black text-slate-950">{title}</h2>
  <ul class="mt-5 grid gap-3 sm:grid-cols-2">
    {items.map((item: string) => (
      <li class="rounded-2xl bg-slate-50 px-4 py-3 text-sm leading-6 text-slate-700">{item}</li>
    ))}
  </ul>
</section>
