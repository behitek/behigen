---
import GroupPricingSummary from '@components/store/GroupPricingSummary.astro';
import { formatPriceLabel, getProductLogoPath } from '@utils/products';

const { product } = Astro.props;
const logoPath = getProductLogoPath(product.category);
---

<article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/60 transition hover:-translate-y-1 hover:shadow-lg">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <a
        href={`${import.meta.env.BASE_URL}store/${product.slug}`}
        class="group block rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-600 focus-visible:ring-offset-2"
      >
        <img
          src={logoPath}
          alt={`${product.category} product badge`}
          class="h-12 w-auto rounded-full border border-slate-200 bg-slate-50"
          loading="lazy"
        />
        <h3 class="mt-2 text-xl font-bold text-slate-950 transition group-hover:text-cyan-700">{product.name}</h3>
      </a>
      <p class="mt-2 text-sm text-slate-600">{product.variant}</p>
    </div>
    <div class="text-right">
      <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Giá niêm yết</div>
      <div class="mt-1 text-2xl font-black text-slate-950">{formatPriceLabel(product.price)}</div>
      <div class="text-sm text-slate-500">{product.billingTerm}</div>
    </div>
  </div>

  <p class="mt-4 text-sm leading-6 text-slate-600">{product.tagline}</p>

  <div class="mt-5">
    <GroupPricingSummary price={product.price} productName={product.name} mode="compact" />
  </div>

  <div class="mt-5 grid gap-3 sm:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
      <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">
        <svg viewBox="0 0 20 20" class="h-4 w-4 text-cyan-700" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"></circle>
          <path d="M10 6V10L12.8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
        Thời gian sử dụng
      </div>
      <div class="mt-2 text-sm font-bold text-slate-950">{product.billingTerm}</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
      <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">
        <svg viewBox="0 0 20 20" class="h-4 w-4 text-emerald-700" fill="none" aria-hidden="true">
          <path d="M10 2.5L15.5 4.8V9.3C15.5 12.7 13.2 15.9 10 16.8C6.8 15.9 4.5 12.7 4.5 9.3V4.8L10 2.5Z" stroke="currentColor" stroke-width="1.5"></path>
          <path d="M7.5 9.8L9.2 11.5L12.7 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        Bảo hành
      </div>
      <div class="mt-2 text-sm font-bold text-slate-950">{product.warranty}</div>
    </div>
  </div>

  <div class="mt-4 rounded-[1.5rem] border border-cyan-200 bg-cyan-50 px-4 py-4">
    <div class="inline-flex rounded-full bg-white px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-cyan-700">
      Dùng riêng
    </div>
    <p class="mt-3 text-sm leading-6 text-slate-700">
      Bàn giao để bạn dùng cá nhân, không phải kiểu account công khai dùng chung với người lạ. Hình thức cụ thể: {product.deliveryType}.
    </p>
  </div>

  <ul class="mt-4 space-y-2 text-sm text-slate-600">
    {product.highlights.slice(0, 3).map((item: string) => <li>• {item}</li>)}
  </ul>

  <a
    href={`${import.meta.env.BASE_URL}store/${product.slug}`}
    class="mt-6 inline-flex rounded-full bg-cyan-600 px-5 py-3 font-semibold text-white transition hover:bg-cyan-700"
  >
    Xem chi tiết
  </a>
</article>
