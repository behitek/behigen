---
import { getCollection } from 'astro:content';
import ZaloButton from '@components/contact/ZaloButton.astro';
import FAQPreview from '@components/content/FAQPreview.astro';
import PostCard from '@components/content/PostCard.astro';
import GroupPricingSelector from '@components/store/GroupPricingSelector.astro';
import ProductCard from '@components/store/ProductCard.astro';
import ToolCard from '@components/tools/ToolCard.astro';
import Layout from '@layouts/Layout.astro';
import { buildContactHref } from '@utils/contact';

const allProducts = await getCollection('products');
const featuredProducts = allProducts
  .filter((entry) => entry.data.featured)
  .sort(
    (a, b) =>
      Number(b.data.featuredEmphasis ?? false) - Number(a.data.featuredEmphasis ?? false)
  )
  .slice(0, 4);
const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const faqGroups = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const featuredTools = (await getCollection('tools')).filter((entry) => entry.data.featured).slice(0, 4);

const zaloHref = buildContactHref({
  basePath: import.meta.env.BASE_URL,
  channel: 'zalo'
});
---

<Layout
  title="Behigen - Mua tài khoản AI với giá công khai và cách chốt rõ ràng"
  description="Behigen do cùng người vận hành luyencode.net xây dựng, có giá niêm yết rõ ràng và hỗ trợ Google products theo hướng dùng trước rồi xác nhận thanh toán."
  canonical="/"
>
  <section class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,_rgba(8,145,178,0.18),_transparent_35%),linear-gradient(135deg,_#ecfeff_0%,_#ffffff_55%,_#f8fafc_100%)] py-20">
    <div class="container">
      <p class="inline-flex rounded-full border border-cyan-200 bg-white px-4 py-2 text-sm font-semibold text-cyan-700">
        Cùng người vận hành luyencode.net
      </p>
      <h1 class="mt-6 max-w-5xl text-5xl font-black tracking-tight text-slate-950">
        Mua tài khoản AI với giá công khai và quy trình chốt đơn rõ ràng
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">
        Behigen do cùng người vận hành luyencode.net xây dựng. Với Google products, bạn có thể dùng trước, xác nhận hoạt động rồi mới thanh toán qua Zalo.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href={`${import.meta.env.BASE_URL}store`} class="rounded-full bg-cyan-600 px-6 py-3 font-semibold text-white">
          Xem cửa hàng
        </a>
        <a href="#purchase-flow" class="rounded-full border border-slate-300 px-6 py-3 font-semibold text-slate-900">
          Xem cách mua
        </a>
      </div>
      <div class="mt-8 flex flex-wrap gap-3 text-sm font-semibold">
        <ZaloButton
          href={zaloHref}
          label="Nhắn Zalo để xác nhận gói và chốt đơn"
          caption="Xác nhận loại account, cách bàn giao và thời điểm thanh toán"
        />
      </div>
      <div class="mt-8 grid gap-3 md:grid-cols-3">
        <div class="rounded-[1.5rem] border border-slate-200 bg-white/90 px-4 py-4 text-sm font-semibold text-slate-800">
          Cùng người vận hành luyencode.net
        </div>
        <div class="rounded-[1.5rem] border border-emerald-200 bg-emerald-50 px-4 py-4 text-sm font-semibold text-emerald-900">
          Google products: dùng trước, xác nhận rồi thanh toán
        </div>
        <div class="rounded-[1.5rem] border border-slate-200 bg-white/90 px-4 py-4 text-sm font-semibold text-slate-800">
          Giá công khai, có bảo hành và cách bàn giao rõ ràng
        </div>
      </div>
    </div>
  </section>

  <section class="container py-16">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-black tracking-tight text-slate-950">Gói nổi bật</h2>
      <p class="mt-3 text-base leading-7 text-slate-600">
        Các gói đang được chọn nhiều nhất bởi sinh viên IT, junior dev và người cần kết hợp AI với lưu trữ.
      </p>
    </div>
    <div class="mt-8 space-y-6" data-group-pricing-root>
      <div class="rounded-[2rem] border border-cyan-200 bg-cyan-50 p-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-cyan-700">
              Mua nhóm càng rẻ
            </p>
            <h3 class="mt-2 text-2xl font-black text-slate-950">
              Mua 2 giảm 10%, mua 3-4 giảm 20%, mua 5+ giảm 30%
            </h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Đang xem giá cho <span class="font-bold text-slate-950" data-group-pricing-quantity>1</span> account trên mỗi gói nổi bật.
            </p>
          </div>
          <GroupPricingSelector inputId="home-group-quantity" quantity={1} label="Số lượng account" />
        </div>
      </div>
      <div class="grid gap-6 lg:grid-cols-2">
        {featuredProducts.map((product) => <ProductCard product={product.data} surface="home" />)}
      </div>
    </div>
    <script>
      import '../components/store/groupPricingClient';
    </script>
  </section>

  <section id="purchase-flow" class="container py-16">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-[2rem] border border-emerald-200 bg-emerald-50 p-6">
        <h2 class="text-2xl font-black text-slate-950">Google: dùng trước rồi thanh toán</h2>
        <p class="mt-5 text-sm leading-6 text-slate-700">
          Với các gói Google, bạn có thể kiểm tra account hoạt động đúng quyền lợi trước khi chốt thanh toán. Mục tiêu là giảm rủi ro cho người mua ngay từ bước đầu.
        </p>
      </div>
      <div class="rounded-[2rem] border border-slate-200 bg-white p-6">
        <h2 class="text-2xl font-black text-slate-950">Bàn giao rõ từng bước</h2>
        <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600">
          <li>• Xác nhận đúng loại account: owner, member, gia hạn hay cấp mới.</li>
          <li>• Nói rõ cách tham gia hoặc bàn giao trước khi chốt.</li>
          <li>• Xác nhận thời gian xử lý và phạm vi bảo hành ngay trên Zalo.</li>
        </ul>
      </div>
      <div class="rounded-[2rem] border border-slate-200 bg-white p-6">
        <h2 class="text-2xl font-black text-slate-950">Zalo là bước chốt đơn</h2>
        <p class="mt-5 text-sm leading-6 text-slate-600">
          Zalo dùng để xác nhận gói, tồn kho, tổng tiền theo số lượng account và hỗ trợ sau khi nhận. Đây là bước hoàn tất đơn, không phải một inbox mơ hồ để hỏi giá.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-16">
    <div class="container">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-3xl font-black tracking-tight text-slate-950">FAQ nổi bật</h2>
        <a href={`${import.meta.env.BASE_URL}faq`} class="text-sm font-semibold text-cyan-700">Xem tất cả FAQ</a>
      </div>
      <div class="mt-8">
        <FAQPreview groups={faqGroups} />
      </div>
    </div>
  </section>

  <section class="container py-16">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-3xl font-black tracking-tight text-slate-950">Tài liệu nên đọc</h2>
      <a href={`${import.meta.env.BASE_URL}blog`} class="text-sm font-semibold text-cyan-700">Đọc blog</a>
    </div>
    <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
      Bài viết dành cho người mới, tập trung vào thứ có thể áp dụng ngay thay vì lý thuyết dài dòng.
    </p>
    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="bg-slate-50 py-16">
    <div class="container">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-3xl font-black tracking-tight text-slate-950">Công cụ thực dụng và LLM Lab</h2>
        <a href={`${import.meta.env.BASE_URL}tools`} class="text-sm font-semibold text-cyan-700">Xem tất cả công cụ</a>
      </div>
      <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
        Một phần để chọn đúng gói mua, một phần để hiểu token, vòng lặp tool use và coding agent theo cách an toàn hơn với tài liệu hiện tại.
      </p>
      <div class="mt-8 grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
        {featuredTools.map((tool) => <ToolCard tool={tool.data} />)}
      </div>
    </div>
  </section>

  <section class="container py-16">
    <div class="rounded-[2rem] bg-slate-950 px-8 py-10 text-white">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-cyan-300">Chốt gói nhanh</p>
      <h2 class="mt-3 text-3xl font-black">Không chắc nên mua gói nào?</h2>
      <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">
        Gửi nhu cầu, số lượng account và ngân sách qua Zalo để xác nhận đúng gói, cách bàn giao và thời điểm thanh toán phù hợp. Với Google products, bạn có thể xác nhận hoạt động trước khi chốt tiền.
      </p>
      <div class="mt-8 flex flex-wrap gap-3 text-sm font-semibold">
        <ZaloButton
          href={zaloHref}
          label="Mở Zalo để xác nhận và chốt đơn"
          caption="Chốt loại account, cách bàn giao và hỗ trợ sau khi nhận"
        />
      </div>
    </div>
  </section>
</Layout>
