---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';

const groups = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="FAQ mua tài khoản AI"
  description="Câu hỏi thường gặp về mua, bảo hành, account share và account chính chủ."
  canonical="/faq"
>
  <section class="container py-16">
    <div class="max-w-3xl">
      <a href={`${import.meta.env.BASE_URL}store`} class="text-sm font-semibold text-cyan-700">Quay lại cửa hàng</a>
      <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950">FAQ</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        Các câu hỏi thường gặp trước khi chốt đơn, từ quy trình bàn giao đến bảo hành và cách chọn đúng gói.
      </p>
    </div>
    <div class="mt-10 space-y-8">
      {groups.map((group) => (
        <section class="rounded-[2rem] border border-slate-200 bg-white p-6">
          <h2 class="text-2xl font-black text-slate-950">{group.data.group}</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">{group.data.description}</p>
          <div class="mt-4 space-y-4">
            {group.data.items.map((item) => (
              <article>
                <h3 class="font-bold text-slate-950">{item.question}</h3>
                <p class="mt-2 text-slate-600">{item.answer}</p>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</Layout>
