---
import { getCollection } from 'astro:content';
import ProductCTA from '@components/store/ProductCTA.astro';
import ProductComparisonTable from '@components/store/ProductComparisonTable.astro';
import ProductHighlights from '@components/store/ProductHighlights.astro';
import Layout from '@layouts/Layout.astro';
import { formatPriceLabel, getProductLogoPath } from '@utils/products';

export async function getStaticPaths() {
  const products = await getCollection('products');

  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product: product.data }
  }));
}

const { product } = Astro.props;
const [allProducts, allPosts, allTools] = await Promise.all([
  getCollection('products'),
  getCollection('blog'),
  getCollection('tools')
]);

const comparisonProducts = allProducts
  .map((entry) => entry.data)
  .filter((entry) => entry.category === product.category)
  .sort((a, b) => {
    if (a.slug === product.slug) return -1;
    if (b.slug === product.slug) return 1;
    return a.price - b.price;
  });
const relatedPosts = allPosts.filter((post) => post.data.relatedProducts.includes(product.slug));
const relatedTools = allTools.filter(
  (tool) => tool.data.toolType === 'practical' && tool.data.relatedProducts.includes(product.slug)
);
const logoPath = getProductLogoPath(product.category);
---

<Layout title={product.seoTitle} description={product.seoDescription} canonical={`/store/${product.slug}`}>
  <section class="container py-16">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <img
          src={logoPath}
          alt={`${product.category} product badge`}
          class="h-14 w-auto rounded-full border border-slate-200 bg-slate-50"
          loading="lazy"
        />
        <h1 class="text-4xl font-black tracking-tight text-slate-950">{product.name}</h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">{product.tagline}</p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 p-4">
            <div class="text-sm text-slate-500">Giá</div>
            <div class="text-3xl font-black text-slate-950">{formatPriceLabel(product.price)}</div>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <div class="text-sm text-slate-500">Thời hạn</div>
            <div class="text-2xl font-bold text-slate-950">{product.billingTerm}</div>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <div class="text-sm text-slate-500">Bảo hành</div>
            <div class="text-2xl font-bold text-slate-950">{product.warranty}</div>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <div class="text-sm text-slate-500">Hình thức</div>
            <div class="text-lg font-bold text-slate-950">{product.deliveryType}</div>
          </div>
        </div>

        <div class="mt-8">
          <ProductHighlights items={product.highlights} />
        </div>

        <ul class="mt-8 space-y-3 text-slate-700">
          {product.details.map((item: string) => <li>• {item}</li>)}
        </ul>
      </div>

      <div class="space-y-6">
        <ProductCTA productName={product.name} />
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6">
          <h2 class="text-2xl font-black text-slate-950">Lưu ý bàn giao</h2>
          <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-600">
            {product.purchaseNotes.map((item: string) => <li>• {item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-16">
    <div class="grid gap-8 lg:grid-cols-2">
      <div class="rounded-[2rem] border border-slate-200 p-6">
        <h2 class="text-2xl font-black text-slate-950">Phù hợp nếu</h2>
        <ul class="mt-4 space-y-2 text-slate-700">
          {product.suitableFor.map((item: string) => <li>• {item}</li>)}
        </ul>
      </div>
      <div class="rounded-[2rem] border border-rose-200 bg-rose-50 p-6">
        <h2 class="text-2xl font-black text-slate-950">Không phù hợp nếu</h2>
        <ul class="mt-4 space-y-2 text-slate-700">
          {product.notSuitableFor.map((item: string) => <li>• {item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="container pb-16">
    <ProductComparisonTable products={comparisonProducts} currentProductSlug={product.slug} />
  </section>

  <section class="container pb-16">
    <div class="grid gap-8 lg:grid-cols-2">
      <div class="rounded-[2rem] border border-slate-200 bg-white p-6">
        <h2 class="text-2xl font-black text-slate-950">FAQ sản phẩm</h2>
        <div class="mt-4 space-y-4">
          {product.faqs.map((item: { question: string; answer: string }) => (
            <article>
              <h3 class="font-bold text-slate-950">{item.question}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{item.answer}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="space-y-8">
        <section class="rounded-[2rem] border border-slate-200 bg-white p-6">
          <h2 class="text-2xl font-black text-slate-950">Bài viết liên quan</h2>
          <div class="mt-4 space-y-3">
            {relatedPosts.length > 0 ? (
              relatedPosts.map((post) => (
                <a class="block rounded-2xl bg-slate-50 px-4 py-3 font-semibold text-slate-900" href={`${import.meta.env.BASE_URL}blog/${post.slug}`}>
                  {post.data.title}
                </a>
              ))
            ) : (
              <p class="text-sm leading-6 text-slate-600">Không có bài viết liên quan trực tiếp, bạn vẫn có thể xem blog để chọn gói phù hợp hơn.</p>
            )}
          </div>
        </section>

        <section class="rounded-[2rem] border border-slate-200 bg-white p-6">
          <h2 class="text-2xl font-black text-slate-950">Công cụ liên quan</h2>
          <div class="mt-4 space-y-3">
            {relatedTools.length > 0 ? (
              relatedTools.map((tool) => (
                <a class="block rounded-2xl bg-slate-50 px-4 py-3 font-semibold text-slate-900" href={`${import.meta.env.BASE_URL}tools/${tool.data.slug}`}>
                  {tool.data.title}
                </a>
              ))
            ) : (
              <p class="text-sm leading-6 text-slate-600">Không có tool gắn trực tiếp với gói này.</p>
            )}
          </div>
        </section>
      </div>
    </div>
  </section>

  <div class="fixed inset-x-4 bottom-4 z-30 rounded-[1.75rem] border border-slate-200 bg-white/95 p-4 shadow-2xl shadow-slate-300/40 md:hidden">
    <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Liên hệ nhanh</p>
    <div class="mt-3">
      <ProductCTA productName={product.name} />
    </div>
  </div>
</Layout>
